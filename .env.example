# ============================================
# DocGuard AI — Environment Configuration
# ============================================
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# --- AWS Credentials ---
AWS_BEARER_TOKEN_BEDROCK=
AWS_REGION=us-east-1
AWS_DEFAULT_REGION=us-east-1

# --- Bedrock Model ---
BEDROCK_MODEL_ID=apac.amazon.nova-lite-v1:0

# --- Debug ---
DEBUG=False

# --- Security Secrets (REQUIRED — generate strong random values) ---
# Internal token for Nginx→Flask bypass (e.g. python3 -c "import uuid;print(f'docguard-{uuid.uuid4()}')")
INTERNAL_TOKEN=

# Flask session signing key (e.g. python3 -c "import secrets;print(secrets.token_hex(32))")
SECRET_KEY=

# --- Database ---
POSTGRES_USER=docguard_admin
POSTGRES_PASSWORD=
POSTGRES_DB=document_analyzer

# --- CORS (comma-separated origins allowed to call the API) ---
# CORS_ORIGINS=https://yourdomain.com